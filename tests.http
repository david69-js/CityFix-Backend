POST {{baseUrl}}/admin/notifications/campaign
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "title": "Mantenimiento Programado",
  "message": "El sistema estará en mantenimiento el sábado de 2am a 4am."
}

